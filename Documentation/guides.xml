<?xml version="1.0" encoding="UTF-8"?>
<guides
    xmlns="https://www.phpdoc.org/guides"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="https://www.phpdoc.org/guides vendor/phpdocumentor/guides-cli/resources/schema/guides.xsd"
    theme="typo3docs"
    default-code-language="php"
    links-are-relative="true"
>
    <project
        title="DOCX Editor"
        version="1.0"
        release="1.1.0"
        copyright="since 2026 by webconsulting"
    />

    <extension
        class="\T3Docs\Typo3DocsTheme\DependencyInjection\Typo3DocsThemeExtension"
        typo3-core-preferred="stable"
        interlink-shortcode="webconsulting/docx-editor"
        project-home="https://github.com/dirnbauer/typo3-docx"
        project-contact="https://github.com/dirnbauer/typo3-docx/issues"
        project-repository="https://github.com/dirnbauer/typo3-docx"
        project-issues="https://github.com/dirnbauer/typo3-docx/issues"
        edit-on-github="dirnbauer/typo3-docx"
        edit-on-github-branch="main"
        edit-on-github-directory="Documentation"
    />

    <inventory id="t3coreapi" url="https://docs.typo3.org/m/typo3/reference-coreapi/main/en-us/"/>
    <inventory id="t3tca" url="https://docs.typo3.org/m/typo3/reference-tca/main/en-us/"/>
</guides>
